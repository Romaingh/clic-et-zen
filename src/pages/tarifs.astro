---
// src/pages/tarifs.astro
import Layout from '../layouts/Layout.astro';

const zones = "Ivry-sur-Seine / Paris 13 & Fontainebleau / Vulaines-sur-Seine";
---

<Layout 
	title="Mes Tarifs Assistance & Dépannage Informatique | Clic&Zen"
	description="Consultez mes tarifs clairs et transparents pour particuliers (agrément crédit d'impôt de 50%) et professionnels. Devis et déplacement gratuits."
>
	<!-- Hero Section -->
	<section class="bg-gradient-to-b from-clic-light to-slate-50 py-16 sm:py-20 border-b border-slate-100">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
			<span class="text-xs font-bold uppercase tracking-wider text-clic-dark bg-clic-medium/20 px-3.5 py-1.5 rounded-full inline-block mb-4">
				Tarifs transparents
			</span>
			<h1 class="font-display text-4xl sm:text-5xl font-black text-slate-900 tracking-tight max-w-4xl mx-auto leading-tight">
				Une tarification claire et sans mauvaise surprise
			</h1>
			<p class="text-slate-600 text-lg sm:text-xl max-w-3xl mx-auto mt-4 leading-relaxed font-medium">
				Mes déplacements sont entièrement gratuits dans mes zones d'intervention. Devis toujours 100% gratuit.
			</p>
		</div>
	</section>

	<!-- Section Grille Tarifaire -->
	<section class="py-16 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6">
			
			<!-- Offre Spéciale de Lancement -->
			<div class="mb-12 max-w-4xl mx-auto bg-gradient-to-r from-amber-50 to-orange-50 border-2 border-amber-300 rounded-3xl p-6 sm:p-8 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm transform hover:scale-[1.01] transition duration-300">
				<div class="space-y-2 text-center md:text-left">
					<span class="bg-amber-200 text-amber-900 font-bold text-xs uppercase tracking-wider px-3 py-1 rounded-full inline-block">
						🎉 Offre Spéciale Particuliers
					</span>
					<h3 class="font-display text-xl sm:text-2xl font-black text-slate-900 leading-tight">
						Votre première heure à 25 € !
					</h3>
					<p class="text-slate-600 text-sm max-w-xl font-medium leading-relaxed">
						Pour toute première intervention à votre domicile, bénéficiez d'un tarif exceptionnel de <strong>25 € après crédit d'impôt</strong> la première heure (soit 50 € brut au lieu de 80 €).
					</p>
				</div>
				<div class="text-center shrink-0 w-full md:w-auto">
					<div class="text-2xl sm:text-3xl font-black text-clic-red font-display">25 € <span class="text-xs">TTC*</span></div>
					<div class="text-xs text-slate-400 font-semibold uppercase tracking-wider mt-1">Jusqu'au 30 septembre</div>
				</div>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch max-w-5xl mx-auto">
				
				<!-- Tarifs Particuliers (🏠) -->
				<div class="bg-slate-50 rounded-3xl p-8 sm:p-10 border border-slate-100 flex flex-col justify-between hover:shadow-xl transition duration-300">
					<div class="space-y-6">
						<div class="flex items-center justify-between border-b border-slate-200/60 pb-4">
							<div>
								<span class="text-xs font-bold uppercase tracking-wider text-clic-dark bg-clic-light px-3 py-1 rounded-full">
									Service à domicile (SAP)
								</span>
								<h3 class="font-display text-2xl font-black text-slate-900 mt-2">Particuliers</h3>
							</div>
							<img src="/images/services_personne.png" alt="Services à la personne" class="h-16 w-auto object-contain" />
						</div>
						
						<!-- Explication crédit d'impôt -->
						<div class="bg-clic-medium/10 border border-clic-medium/20 rounded-xl p-4 text-xs text-clic-dark font-medium leading-relaxed">
							⭐️ <strong>Crédit d'Impôt Immédiat :</strong> Je suis agréé Service à la Personne (SAP). Avec l'Avance Immédiate de l'URSSAF, vous ne payez que le coût net après réduction (la moitié de la facture) !
						</div>

						<!-- Liste des tarifs particuliers -->
						<div class="space-y-4 pt-2">
							
							<!-- Ligne 1: Première heure -->
							<div class="bg-white p-4 rounded-xl border border-slate-100 flex items-center justify-between gap-4">
								<div>
									<h4 class="font-bold text-slate-900 text-base sm:text-lg">Première heure</h4>
								</div>
								<div class="text-right shrink-0">
									<div class="text-sm text-slate-500 line-through">80 € TTC</div>
									<div class="text-xl sm:text-2xl font-black text-clic-red font-display">40 € <span class="text-sm">TTC*</span></div>
								</div>
							</div>
							
							<!-- Ligne 2: Demie heure sup -->
							<div class="bg-white p-4 rounded-xl border border-slate-100 flex items-center justify-between gap-4">
								<div>
									<h4 class="font-bold text-slate-900 text-base sm:text-lg">Demi-heure suivante</h4>
									<p class="text-slate-600 text-sm mt-0.5">Toute demi-heure supplémentaire</p>
								</div>
								<div class="text-right shrink-0">
									<div class="text-sm text-slate-500 line-through">30 € TTC</div>
									<div class="text-xl sm:text-2xl font-black text-clic-red font-display">15 € <span class="text-sm">TTC*</span></div>
								</div>
							</div>

						</div>
					</div>
					
					<div class="pt-8 border-t border-slate-200/60 mt-6 text-center text-sm text-slate-500 leading-relaxed">
						* Tarifs après réduction immédiate de 50% de crédit d'impôt. <br />
						Les déplacements sont inclus dans mes zones.
					</div>
				</div>
				
				<!-- Tarifs Professionnels (💼) -->
				<div class="bg-slate-50 rounded-3xl p-8 sm:p-10 border border-slate-100 flex flex-col justify-between hover:shadow-xl transition duration-300">
					<div class="space-y-6">
						<div class="flex items-center justify-between border-b border-slate-200/60 pb-4">
							<div>
								<span class="text-xs font-bold uppercase tracking-wider text-clic-red bg-red-50 px-3 py-1 rounded-full">
									Entreprises & Indépendants
								</span>
								<h3 class="font-display text-2xl font-black text-slate-900 mt-2">Professionnels</h3>
							</div>
							<span class="text-3xl">💼</span>
						</div>
						
						<!-- Explication crédit d'impôt pro -->
						<div class="bg-slate-200/60 border border-slate-300/40 rounded-xl p-4 text-xs text-slate-700 font-medium leading-relaxed">
							💼 <strong>Fiscalité Professionnelle :</strong> Facturation en Hors Taxes (HT) avec TVA récupérable. Prestations déductibles des charges de votre entreprise.
						</div>

						<!-- Liste des tarifs pro -->
						<div class="space-y-4 pt-2">
							
							<!-- Ligne 1: Taux horaire pro -->
							<div class="bg-white p-4 rounded-xl border border-slate-100 flex items-center justify-between gap-4">
								<div>
									<h4 class="font-bold text-slate-900 text-base sm:text-lg">Taux horaire d'assistance</h4>
									<p class="text-slate-600 text-sm mt-0.5">Dépannage, réseau, postes de travail</p>
								</div>
								<div class="text-right shrink-0">
									<div class="text-xl sm:text-2xl font-black text-clic-dark font-display">80€ <span class="text-sm">HT / h</span></div>
									<div class="text-xs text-slate-400"></div>
								</div>
							</div>
							
							<!-- Ligne 2: Audit et réseau -->
							<div class="bg-white p-4 rounded-xl border border-slate-100 flex items-center justify-between gap-4">
								<div>
									<h4 class="font-bold text-slate-900 text-base sm:text-lg">Forfait demie-journée</h4>
								</div>
								<div class="text-right shrink-0">
									<div class="text-xl sm:text-2xl font-black text-clic-dark font-display">200€ <span class="text-sm">HT</span></div>
									<div class="text-xs text-slate-400"></div>
								</div>
							</div>
							
							<!-- Ligne 3: Journée -->
							<div class="bg-white p-4 rounded-xl border border-slate-100 flex items-center justify-between gap-4">
								<div>
									<h4 class="font-bold text-slate-900 text-base sm:text-lg">Forfait journée</h4>
								</div>
								<div class="text-right shrink-0">
									<div class="text-xl sm:text-2xl font-black text-clic-dark font-display">350€ <span class="text-sm">HT</span> </div>
									<div class="text-xs text-slate-400"></div>
								</div>
							</div>

						</div>
					</div>
					
					<div class="pt-8 border-t border-slate-200/60 mt-6 text-center text-sm text-slate-500 leading-relaxed">
						Facture HT émise pour votre comptabilité. <br />
						Déplacement inclus dans mes zones. Devis gratuit sans engagement.
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- Section Garanties de Facturation -->
	<section class="py-16 bg-slate-50 border-t border-slate-100">
		<div class="max-w-4xl mx-auto px-4 sm:px-6">
			
			<div class="bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-slate-100 space-y-8">
				<h3 class="font-display text-2xl font-extrabold text-slate-900 text-center">
					Mes engagements de facturation
				</h3>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					
					<!-- Engagement 1 -->
					<div class="bg-slate-50 p-6 rounded-2xl border border-slate-100/80 flex gap-4 items-start hover:border-clic-medium/20 transition duration-300">
						<span class="text-3xl shrink-0">📋</span>
						<div class="space-y-1">
							<h4 class="font-bold text-slate-900 text-base sm:text-lg">Aucun frais caché</h4>
							<p class="text-slate-600 text-sm leading-relaxed">
								Mes déplacements sont entièrement gratuits dans mes zones d'intervention. Le devis est établi sur place et validé par vos soins avant le début de mon travail.
							</p>
						</div>
					</div>

					<!-- Engagement 2 -->
					<div class="bg-slate-50 p-6 rounded-2xl border border-slate-100/80 flex gap-4 items-start hover:border-clic-medium/20 transition duration-300">
						<span class="text-3xl shrink-0">💳</span>
						<div class="space-y-1">
							<h4 class="font-bold text-slate-900 text-base sm:text-lg">Règlements acceptés</h4>
							<p class="text-slate-600 text-sm leading-relaxed">
								Pour votre commodité, j'accepte les règlements par virement, carte bancaire, ou chèque CESU préfinancé. Facture acquittée immédiate.
							</p>
						</div>
					</div>

				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-16 bg-gradient-to-br from-clic-light to-white text-center">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 space-y-6">
			<h2 class="font-display text-3xl font-extrabold text-slate-900 tracking-tight">
				Une question sur mes tarifs ?
			</h2>
			<p class="text-slate-600 text-lg max-w-2xl mx-auto leading-relaxed">
				N'hésitez pas à m'appeler. Je vous donnerai une estimation immédiate par téléphone pour votre cas particulier.
			</p>
			
			<div class="flex flex-col sm:flex-row justify-center items-center gap-4 pt-4">
				<div class="w-full sm:w-auto bg-clic-red text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-clic-red/20 flex items-center justify-center gap-3 text-base">
					<span>📞 M'appeler au 07 67 73 32 70</span>
				</div>
				<a href="/faq" class="w-full sm:w-auto border-2 border-clic-dark text-clic-dark hover:bg-clic-dark hover:text-white font-bold px-8 py-3.5 rounded-xl transition text-base text-center">
					Consulter ma FAQ
				</a>
			</div>
		</div>
	</section>
</Layout>
