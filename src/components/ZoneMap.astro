---
// src/components/ZoneMap.astro
// Reusable vector-based map component showing intervention zones in Île-de-France
---

<div class="bg-slate-50 rounded-3xl p-6 border border-slate-100 shadow-sm space-y-6">
	<div class="space-y-2">
		<h3 class="font-display text-lg font-bold text-slate-900 flex items-center gap-2">
			<span>📍</span> Mon secteur d'intervention
		</h3>
		<p class="text-xs text-slate-500 leading-relaxed">
			Je me déplace gratuitement chez vous dans les zones ci-dessous. Au-delà, contactez-moi pour étudier la faisabilité.
		</p>
	</div>

	<!-- Map Container -->
	<div class="relative w-full aspect-[4/3] bg-white rounded-2xl border border-slate-100 shadow-inner overflow-hidden">
		<!-- SVG Stylisé IDF avec 92, 93, 94 individuels -->
		<svg class="w-full h-full p-4" viewBox="0 0 400 320" fill="none" xmlns="http://www.w3.org/2000/svg">
			<!-- Yvelines (78) -->
			<path d="M 50 140 L 95 230 L 140 185 L 135 110 L 90 95 Z" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2" stroke-linejoin="round"/>
			<!-- Essonne (91) -->
			<path d="M 95 230 L 180 275 L 205 185 L 140 185 Z" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2" stroke-linejoin="round"/>
			<!-- Seine-et-Marne (77) - Zone d'activité en bleu clair -->
			<path d="M 205 185 L 180 275 L 305 295 L 350 205 L 320 85 L 235 80 C 235 80 215 130 205 185 Z" fill="#e6f0f6" stroke="#89b2ce" stroke-width="2.5" stroke-linejoin="round"/>
			<!-- Val d'Oise (95) -->
			<path d="M 90 95 L 235 80 L 210 115 L 135 110 Z" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2" stroke-linejoin="round"/>

			<!-- Hauts-de-Seine (92) - Voisin Ouest -->
			<path d="M 135 110 L 160 135 L 165 150 L 155 170 L 140 185 Z" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" stroke-linejoin="round"/>
			<!-- Seine-Saint-Denis (93) - Voisin Nord-Est -->
			<path d="M 160 135 L 210 115 L 215 135 L 185 130 Z" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" stroke-linejoin="round"/>
			<!-- Val-de-Marne (94) - Zone d'activité active Sud-Est (Ivry) -->
			<path d="M 165 150 L 190 145 L 215 135 L 205 185 L 140 185 L 155 170 Z" fill="#d0e1ee" stroke="#89b2ce" stroke-width="2" stroke-linejoin="round"/>
			<!-- Paris (75) - Zone d'activité active -->
			<path d="M 160 135 L 185 130 L 190 145 L 165 150 Z" fill="#d0e1ee" stroke="#89b2ce" stroke-width="2" stroke-linejoin="round"/>

			<!-- Textes des départements en filigrane -->
			<text x="80" y="145" class="fill-slate-400 font-sans font-bold text-[9px] tracking-wider pointer-events-none select-none opacity-40">YVELINES (78)</text>
			<text x="120" y="225" class="fill-slate-400 font-sans font-bold text-[9px] tracking-wider pointer-events-none select-none opacity-40">ESSONNE (91)</text>
			<text x="125" y="80" class="fill-slate-400 font-sans font-bold text-[9px] tracking-wider pointer-events-none select-none opacity-40">VAL-D'OISE (95)</text>
			<text x="260" y="160" class="fill-clic-dark/50 font-sans font-bold text-[10px] tracking-wider pointer-events-none select-none opacity-60">SEINE-ET-MARNE (77)</text>

			<!-- Départements Petite Couronne -->
			<text x="145" y="132" class="fill-slate-400 font-sans font-bold text-[8px] tracking-wider pointer-events-none select-none opacity-40">92</text>
			<text x="190" y="125" class="fill-slate-400 font-sans font-bold text-[8px] tracking-wider pointer-events-none select-none opacity-40">93</text>
			<text x="168" y="144" class="fill-clic-dark/80 font-sans font-bold text-[7px] pointer-events-none select-none font-display">75</text>
			<text x="156" y="174" class="fill-clic-dark/70 font-sans font-bold text-[8px] tracking-wider pointer-events-none select-none">VAL-DE-MARNE (94)</text>
		</svg>

		<!-- Pins interactifs (HTML absolu) -->
		
		<!-- Pôle 1: Ivry-sur-Seine / Paris 13 (Ajusté sur Paris/Ivry) -->
		<div class="absolute left-[46%] top-[46%] -translate-x-1/2 -translate-y-1/2 group">
			<div class="absolute -inset-2.5 rounded-full bg-clic-red/30 animate-ping"></div>
			<div class="relative h-3.5 w-3.5 rounded-full bg-clic-red border-2 border-white shadow-md cursor-help"></div>
			<!-- Info-bulle -->
			<div class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-[10px] sm:text-xs font-bold px-2 py-1 rounded shadow-md whitespace-nowrap opacity-90 transition group-hover:opacity-100">
				📍 Ivry-sur-Seine / Paris 13
			</div>
		</div>

		<!-- Pôle 2: Fontainebleau / Vulaines-sur-Seine -->
		<div class="absolute left-[62%] top-[72%] -translate-x-1/2 -translate-y-1/2 group">
			<div class="absolute -inset-2.5 rounded-full bg-clic-red/30 animate-ping"></div>
			<div class="relative h-3.5 w-3.5 rounded-full bg-clic-red border-2 border-white shadow-md cursor-help"></div>
			<!-- Info-bulle -->
			<div class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-[10px] sm:text-xs font-bold px-2 py-1 rounded shadow-md whitespace-nowrap opacity-90 transition group-hover:opacity-100">
				📍 Fontainebleau / Vulaines
			</div>
		</div>
	</div>

	<!-- Légende descriptive -->
	<div class="space-y-3 pt-2 text-xs border-t border-slate-100">
		<h4 class="font-bold text-slate-800 uppercase tracking-wider text-[10px]">Légende de mes zones</h4>
		
		<div class="space-y-2.5 text-slate-600">
			<div class="flex items-start gap-2.5">
				<span class="inline-block w-3 h-3 rounded bg-[#d0e1ee] border border-[#89b2ce] shrink-0 mt-0.5"></span>
				<div>
					<strong class="text-slate-900">Zone Nord (Paris Sud & Val-de-Marne)</strong>
					<p class="text-slate-500 text-[11px] mt-0.5">Dépannage à Ivry-sur-Seine, Paris 13, Le Kremlin-Bicêtre, Villejuif, Charenton-le-Pont...</p>
				</div>
			</div>
			
			<div class="flex items-start gap-2.5">
				<span class="inline-block w-3 h-3 rounded bg-[#e6f0f6] border border-[#89b2ce] shrink-0 mt-0.5"></span>
				<div>
					<strong class="text-slate-900">Zone Sud (Sud Seine-et-Marne)</strong>
					<p class="text-slate-500 text-[11px] mt-0.5">Dépannage à Fontainebleau, Vulaines-sur-Seine, Avon, Samoreau, Thomery, Veneux-les-Sablons...</p>
				</div>
			</div>
		</div>

		<div class="bg-clic-medium/10 border border-clic-medium/20 rounded-xl p-3.5 text-[11px] text-clic-dark font-medium flex items-center gap-2">
			<span>🚗</span>
			<span><strong>Frais de déplacement :</strong> Inclus et gratuits dans toutes ces communes.</span>
		</div>
	</div>
</div>
